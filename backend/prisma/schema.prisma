datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  WAREHOUSE_MANAGER
  SUPPLIER
  ANALYST
}

enum OrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertCategory {
  INVENTORY
  SUPPLIER
  LOGISTICS
  DEMAND
}

enum TraceabilityStage {
  SUPPLIER
  FACTORY
  WAREHOUSE
  DISTRIBUTOR
  CUSTOMER
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(ANALYST)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reports       Report[]
  notifications Notification[]
}

model Product {
  id               String            @id @default(uuid())
  name             String
  sku              String            @unique
  description      String?
  category         String
  price            Float
  safetyStock      Int               @default(50)
  reorderPoint     Int               @default(100)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  inventories      Inventory[]
  orders           Order[]
  forecasts        Forecast[]
  traceabilityLogs TraceabilityLog[]
}

model Warehouse {
  id          String      @id @default(uuid())
  name        String
  location    String
  capacity    Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  inventories Inventory[]
}

model Inventory {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int
  batchNumber String?
  expiryDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model Supplier {
  id                  String   @id @default(uuid())
  name                String
  contactEmail        String
  contactPhone        String?
  address             String?
  rating              Float    @default(5.0)
  deliverySpeedDays   Float    @default(5.0)
  unitCostUsd         Float    @default(10.0)
  reliabilityPct      Float    @default(100.0)
  defectRatePct       Float    @default(0.0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  orders              Order[]
}

model Order {
  id           String      @id @default(uuid())
  supplierId   String
  supplier     Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId    String
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity     Int
  cost         Float
  status       OrderStatus @default(PENDING)
  orderDate    DateTime    @default(now())
  deliveryDate DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  shipments    Shipment[]
}

model Shipment {
  id              String      @id @default(uuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  routeInfo       String?     // JSON string representation of coordinates
  status          OrderStatus @default(PENDING)
  currentLat      Float?
  currentLng      Float?
  eta             DateTime?
  fuelConsumed    Float       @default(0.0)
  carbonEmissions Float       @default(0.0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Forecast {
  id               String   @id @default(uuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  forecastDate     DateTime
  forecastedDemand Float
  forecastType     String   // DAILY, WEEKLY, MONTHLY
  accuracy         Float    @default(90.0)
  createdAt        DateTime @default(now())
}

model RiskAlert {
  id          String        @id @default(uuid())
  category    AlertCategory
  source      String
  message     String
  riskScore   Float
  riskLevel   RiskLevel
  resolved    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TraceabilityLog {
  id           String            @id @default(uuid())
  productId    String
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationName String
  stage        TraceabilityStage
  timestamp    DateTime          @default(now())
  details      String?
  handlerId    String?
  qrCodeUrl    String?
}

model Report {
  id           String   @id @default(uuid())
  title        String
  type         String   // INVENTORY, FORECAST, SUPPLIER, RISK
  format       String   // PDF, EXCEL, CSV
  fileUrl      String?
  generatedBy  User?    @relation(fields: [generatedById], references: [id], onDelete: SetNull)
  generatedById String?
  createdAt    DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  type      String   // LOW_STOCK, SUPPLIER_RISK, SHIPMENT_DELAY, FORECAST_ANOMALY
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
